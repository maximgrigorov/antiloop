# antiloop-proxy example environment for a local llama.cpp deployment
# paired with qwen3-coder-next (including IQ3 variants).
#
# This file is NOT auto-loaded by the proxy.
# Load it explicitly before starting the service, for example:
#   set -a; source .env; set +a
#   python -m antiloop_proxy
# or convert the values into systemd Environment=/EnvironmentFile= entries.

# Upstream OpenAI-compatible llama.cpp server
PROXY_UPSTREAM=http://127.0.0.1:8080

# Proxy listener
PROXY_HOST=127.0.0.1
PROXY_PORT=8081

# Start with balanced for qwen3-coder-next IQ3.
# Switch to strict only if the model repeatedly stops after tool results.
PROXY_MODE=balanced

# Logging
PROXY_LOG_DIR=./logs
PROXY_REDACT_LOGS=true
PROXY_PREVIEW_LENGTH=160

# Timeouts
PROXY_REQUEST_TIMEOUT=300
PROXY_PASSTHROUGH_TIMEOUT=60

# Default completion shaping
PROXY_MAX_TOKENS_OVERRIDE=32768
PROXY_FORCE_TOOL_CHOICE_WHEN_TOOL_LAST=true

# Anti-loop heuristics
PROXY_LOOP_MESSAGE_LOOKBACK=10
PROXY_LOOP_MIN_TOOL_RESULTS=3
PROXY_LOOP_MIN_COMMON_TOKENS=2
PROXY_LOOP_SIMILARITY_RATIO=1.25
